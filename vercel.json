{
  "buildCommand": "",
  "outputDirectory": ".",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/pages/index.html" },
    { "source": "/engine", "destination": "/pages/engine.html" },
    { "source": "/features", "destination": "/pages/features.html" },
    { "source": "/sources", "destination": "/pages/sources.html" },
    { "source": "/privacy", "destination": "/pages/privacy.html" },
    { "source": "/terms", "destination": "/pages/terms.html" },
    { "source": "/demo", "destination": "/pages/demo.html" },
    { "source": "/compare", "destination": "/pages/compare.html" },
    { "source": "/faq", "destination": "/pages/faq.html" },
    { "source": "/changelog", "destination": "/pages/changelog.html" },
    { "source": "/install", "destination": "/pages/install.html" },
    { "source": "/about", "destination": "/pages/about.html" },
    { "source": "/api", "destination": "/pages/api.html" },
    { "source": "/security", "destination": "/pages/security.html" },
    { "source": "/support", "destination": "/pages/support.html" },
    { "source": "/auth", "destination": "/pages/auth.html" },
    { "source": "/account", "destination": "/pages/account.html" },
    { "source": "/pricing", "destination": "/pages/pricing.html" },
    { "source": "/proof", "destination": "/pages/proof.html" }
  ],
  "redirects": [
    {
      "source": "/token",
      "destination": "https://antares-extension.vercel.app/token.html",
      "permanent": false,
      "has": [{ "type": "query", "key": "ca" }]
    },
    {
      "source": "/token.html",
      "destination": "https://antares-extension.vercel.app/token.html",
      "permanent": false,
      "has": [{ "type": "query", "key": "ca" }]
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/favicon.png",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/demo",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/pricing",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/account",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/auth",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ]
}
